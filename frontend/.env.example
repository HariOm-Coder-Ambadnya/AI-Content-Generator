# Rename this file to .env and fill in your values
# Get Firebase config from: Firebase Console → Project Settings → Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Get Groq API key from: https://console.groq.com/keys
# This replaces the legacy Gemini integration for better performance.
VITE_GROQ_API_KEY=your_groq_api_key

# Backend URL (Render endpoint)
VITE_BACKEND_URL=https://your-backend.onrender.com
