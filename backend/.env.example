# Render automatically sets PORT, but for local dev you can set it here
PORT=8080

# Path to your firebase-service-account.json (relative or absolute)
# Use this for local development if you have the file.
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# OR 1: Paste the entire content of firebase-service-account.json here
# (Note: Multi-line / quotes in raw JSON can sometimes cause issues in cloud env configs)
FIREBASE_SERVICE_ACCOUNT_JSON=

# OR 2 [RECOMMENDED FOR RENDER]: Paste the Base64 ENCODED version of your JSON file.
# Run `base64 -i firebase-service-account.json` (Mac/Linux) or use an online tool
# to convert your json into a single base64 string and paste it below. This avoids quote/newline issues!
FIREBASE_SERVICE_ACCOUNT_BASE64=
