# Render automatically sets PORT, but for local dev you can set it here
PORT=8080

# Path to your firebase-service-account.json (relative or absolute)
# Use this for local development if you have the file.
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

# OR: Paste the entire content of firebase-service-account.json here
# This is the RECOMMENDED way for Render. You can paste the JSON exactly as it is.
FIREBASE_SERVICE_ACCOUNT_JSON=
